FROM node:18-alpine

WORKDIR /app

# Install dependencies for native modules
RUN apk add --no-cache python3 make g++

# Copy workspace root and package files
COPY package*.json ./
COPY backend/package*.json ./backend/
COPY frontend/package*.json ./frontend/
COPY packages/shared/package*.json ./packages/shared/

# Install all dependencies
RUN npm ci --ignore-scripts && npm cache clean --force

# Copy shared package source and build it
COPY packages/shared/tsconfig.json ./packages/shared/
COPY packages/shared/src ./packages/shared/src
RUN npx -w @firevision/shared tsc

# Copy backend tsconfig (needed by tsx for path resolution)
COPY backend/tsconfig.json ./backend/

# Create directories for uploads and APKs
RUN mkdir -p uploads apks && chmod 755 uploads apks

EXPOSE 3000

# Use tsx watch for hot reload
CMD ["npx", "tsx", "watch", "backend/src/server.js"]
