##########################
# Core Server Configuration
##########################

PORT=3000
NODE_ENV=production
APP_VERSION=0.0.0

##########################
# Database
##########################

MONGODB_URI=mongodb://mongodb:27017/firevision-iptv

##########################
# Redis (optional - app works without it)
##########################

REDIS_URL=redis://localhost:6379

##########################
# CORS
##########################

ALLOWED_ORIGINS=*

##########################
# Super Admin (initial setup)
##########################

SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_PASSWORD=admin123
SUPER_ADMIN_EMAIL=admin@yourdomain.com

# Channel list code for the super admin user (used by the TV app)
SUPER_ADMIN_CHANNEL_LIST_CODE=5T6FEP

##########################
# Test User (optional — only created if TEST_USER_USERNAME is set)
##########################

TEST_USER_USERNAME=testuser
TEST_USER_PASSWORD=TestUser123!
TEST_USER_EMAIL=testuser@firevision.local
# TEST_USER_CHANNEL_LIST_CODE=TEST01

##########################
# OAuth Providers
##########################

# Google OAuth (create credentials at https://console.developers.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8009/api/v1/auth/google/callback

# GitHub OAuth (create OAuth app at https://github.com/settings/developers)
GH_OAUTH_CLIENT_ID=your-github-client-id
GH_OAUTH_CLIENT_SECRET=your-github-client-secret
GH_OAUTH_REDIRECT_URI=http://localhost:8009/api/v1/auth/github/callback

##########################
# JWT Secrets
##########################

JWT_ACCESS_SECRET=your-access-secret
JWT_REFRESH_SECRET=your-refresh-secret

##########################
# App Updates / APK (GitHub Releases)
##########################

# GitHub repo that hosts the FireVisionIPTV APK releases
GH_APP_OWNER=akshaynikhare
GH_APP_REPO=FireVisionIPTV

# Pattern to choose the APK asset from a release
# e.g. firevision-iptv-release.apk or just .apk
GH_APP_APK_PATTERN=.apk

# Optional: GitHub token for higher API rate limits (no scopes required)
# GH_APP_TOKEN=ghp_your_token_here

##########################
# Email / SMTP
##########################

# Provider: 'brevo' (production) or 'mailhog' (development)
MAIL_PROVIDER=mailhog

# Brevo SMTP settings (required when MAIL_PROVIDER=brevo)
BREVO_HOST=smtp-relay.brevo.com
BREVO_PORT=587
BREVO_USER=your-brevo-smtp-key
BREVO_PASSWORD=your-brevo-smtp-password

# Sender address
MAIL_FROM=noreply@firevision.local

# Frontend URL (used in email links)
APP_URL=http://localhost:3001

##########################
# Background Scheduler
##########################

# Set to 'true' on the API container when the scheduler runs as a separate Docker service
# DISABLE_SCHEDULER=true

# Interval between automated batch liveness checks (default: 24 hours)
LIVENESS_CHECK_INTERVAL_MS=86400000

# Interval between EPG guide refreshes (default: 6 hours)
EPG_REFRESH_INTERVAL_MS=21600000

# Interval between IPTV-org cache refreshes (default: 1 hour)
CACHE_REFRESH_INTERVAL_MS=3600000

# Interval between stream health checks with auto-promotion (default: 4 hours)
STREAM_HEALTH_CHECK_INTERVAL_MS=14400000

# Interval between YouTube stream URL refreshes (default: 4 hours)
YOUTUBE_REFRESH_INTERVAL_MS=14400000

##########################
# YouTube / Free Sources
##########################

# Max concurrent yt-dlp processes for resolving YouTube live stream URLs
YT_DLP_CONCURRENCY=3
