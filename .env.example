##########################
# Core Server Configuration
##########################

PORT=3000
NODE_ENV=development
APP_VERSION=0.0.0

##########################
# Database
##########################

MONGODB_URI=mongodb://mongodb:27017/firevision-iptv

##########################
# Redis (optional - app works without it)
##########################

# Use redis://redis:6379 when running with Docker Compose (container hostname)
# Use redis://localhost:6379 when running outside Docker
REDIS_URL=redis://localhost:6379

##########################
# CORS
##########################

ALLOWED_ORIGINS=*

# Set to 'true' ONLY when deployed behind Cloudflare, so rate limiting keys off
# the real client IP (CF-Connecting-IP). Leave unset/false for direct exposure —
# otherwise the header is client-spoofable and defeats rate limiting.
# TRUST_CF_CONNECTING_IP=false

##########################
# Super Admin (initial setup)
##########################

SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_PASSWORD=CHANGE-ME-strong-password
SUPER_ADMIN_EMAIL=admin@yourdomain.com

# Set to 'true' to force-update the existing admin's password on next boot
# FORCE_UPDATE_ADMIN_PASSWORD=false

# Channel list code for the super admin user (used by the TV app)
SUPER_ADMIN_CHANNEL_LIST_CODE=5T6FEP

# "Browse Demo Channels" in the TV app pairs to this code. Point it at a dedicated
# non-admin user with a small curated channel list. If unset, falls back to the
# super-admin code (whose list is the whole catalog, capped by TV_CHANNELS_MAX).
# DEMO_CHANNEL_LIST_CODE=DEMO01

# Max channels the TV app receives per sync. Bounds the admin/demo firehose so the
# app stays usable (a normal user's own selection is always returned in full).
TV_CHANNELS_MAX=2000

##########################
# Test User (optional — only created if TEST_USER_USERNAME is set)
##########################

# Dev-only: never enable in production (creation is refused when NODE_ENV=production).
# TEST_USER_USERNAME=testuser
# TEST_USER_PASSWORD=CHANGE-ME-dev-only
# TEST_USER_EMAIL=testuser@firevision.local
# TEST_USER_CHANNEL_LIST_CODE=TEST01

##########################
# OAuth Providers
##########################

# Google OAuth (create credentials at https://console.developers.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8009/api/v1/auth/google/callback

# GitHub OAuth (create OAuth app at https://github.com/settings/developers)
GH_OAUTH_CLIENT_ID=your-github-client-id
GH_OAUTH_CLIENT_SECRET=your-github-client-secret
GH_OAUTH_REDIRECT_URI=http://localhost:8009/api/v1/auth/github/callback

##########################
# JWT Secrets
##########################

# Generate strong secrets: openssl rand -hex 32
JWT_ACCESS_SECRET=CHANGE-ME-run-openssl-rand-hex-32
JWT_REFRESH_SECRET=CHANGE-ME-run-openssl-rand-hex-32

# Access token lifetime (default: 15m)
# JWT_ACCESS_TTL=15m
# Refresh token lifetime in ms (default: 30 days)
# JWT_REFRESH_TTL_MS=2592000000

##########################
# App Updates / APK (GitHub Releases)
##########################

# GitHub repo that hosts the FireVisionIPTV APK releases
GH_APP_OWNER=akshaynikhare
GH_APP_REPO=FireVisionIPTV

# Pattern to choose the APK asset from a release
# e.g. firevision-iptv-release.apk or just .apk
GH_APP_APK_PATTERN=.apk

# Optional: GitHub token for higher API rate limits (no scopes required)
# GH_APP_TOKEN=ghp_your_token_here

##########################
# Email / SMTP
##########################

# Provider: 'brevo' (production) or 'mailhog' (development)
MAIL_PROVIDER=mailhog

# MailHog SMTP settings (used when MAIL_PROVIDER=mailhog)
# MAILHOG_HOST=localhost
# MAILHOG_PORT=1025

# mongo-express dev admin UI basic-auth (docker-compose.yml). Override the defaults.
# ME_CONFIG_BASICAUTH_USERNAME=admin
# ME_CONFIG_BASICAUTH_PASSWORD=CHANGE-ME-dev-only

# Brevo SMTP settings (required when MAIL_PROVIDER=brevo)
BREVO_HOST=smtp-relay.brevo.com
BREVO_PORT=587
BREVO_USER=your-brevo-smtp-key
BREVO_PASSWORD=your-brevo-smtp-password

# Sender address
MAIL_FROM=noreply@firevision.local

# Frontend URL (used in email links)
APP_URL=http://localhost:3001

##########################
# Background Scheduler
##########################

# Set to 'true' on the API container when the scheduler runs as a separate Docker service
# DISABLE_SCHEDULER=true

# Interval between automated batch liveness checks (default: 24 hours)
LIVENESS_CHECK_INTERVAL_MS=86400000

# Interval between EPG guide refreshes (default: 6 hours)
EPG_REFRESH_INTERVAL_MS=21600000

# Interval between IPTV-org cache refreshes (default: 1 hour)
CACHE_REFRESH_INTERVAL_MS=3600000

# Interval between stream health checks with auto-promotion (default: 4 hours)
STREAM_HEALTH_CHECK_INTERVAL_MS=14400000

# Interval between YouTube stream URL refreshes (default: 4 hours)
YOUTUBE_REFRESH_INTERVAL_MS=14400000

##########################
# YouTube / Free Sources
##########################

# Max concurrent yt-dlp processes for resolving YouTube live stream URLs
YT_DLP_CONCURRENCY=3

##########################
# Tuning (optional — sensible defaults shown)
##########################

# TV pairing PIN expiry in minutes (default: 10)
# PAIRING_PIN_EXPIRY_MINUTES=10

# Max signup attempts per rate-limit window (default: 10)
# SIGNUP_RATE_LIMIT_MAX=10

# Concurrency for stream health checks (default: 10)
# STREAM_HEALTH_CONCURRENCY=10

# External source cache TTL in ms (default: 1 hour)
# EXT_SOURCE_CACHE_TTL_MS=3600000
# External source liveness check concurrency (default: 20)
# EXT_SOURCE_LIVENESS_CONCURRENCY=20

# IPTV-org cache TTL in ms (default: 1 hour)
# IPTV_ORG_CACHE_TTL_MS=3600000
# IPTV-org liveness check concurrency (default: 20)
# IPTV_ORG_LIVENESS_CONCURRENCY=20

##########################
# Docker Images (required for docker-compose.selfhost.yml and docker-compose.production.yml)
##########################

DOCKER_IMAGE=ghcr.io/akshaynikhare/firevisioniptvserver:latest
DOCKER_FRONTEND_IMAGE=ghcr.io/akshaynikhare/firevisioniptvserver-frontend:latest

##########################
# Google reCAPTCHA v3 (bot protection on registration)
##########################

# Create keys at https://www.google.com/recaptcha/admin (choose reCAPTCHA v3)
GOOGLE_RECAPTCHA_SITE_KEY=
GOOGLE_RECAPTCHA_SECRET_KEY=

##########################
# Error Tracking
##########################

# Get from https://sentry.io — backend error tracking
BACKEND_SENTRY_DSN=
# Frontend Sentry DSN (can be same as SENTRY_DSN or a separate project)
FRONTEND_SENTRY_DSN=

##########################
# Analytics
##########################

# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX)
GA_MEASUREMENT_ID=
